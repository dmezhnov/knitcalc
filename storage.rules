rules_version = '2';

// Each user can read and write only files under their own folder. Photos live
// at users/{uid}/projects/{projectId}/{photoId}. Everything else is denied.
service firebase.storage {
  match /b/{bucket}/o {
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
