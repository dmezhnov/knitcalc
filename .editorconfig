root = true

[**]
end_of_line = lf
insert_final_newline = true
charset = utf-8
indent_style = space
indent_size = 4
max_line_length = 80
trim_trailing_whitespace = true
quote_type = single
spaces_around_operators = true
spaces_around_brackets = true

[**.gitattributes]
max_line_length = 100

[**/.vscode/settings.json]
max_line_length = 200

[**/.github/workflows/**.{yml,yaml}]
max_line_length = 90
