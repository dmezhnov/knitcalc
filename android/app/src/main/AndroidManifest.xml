<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Sideload self-update: download a release APK and launch the installer. -->
    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES"/>
    <!-- Required (since API 26) for the system uninstaller to actually show its
         confirmation dialog when we launch ACTION_DELETE / ACTION_UNINSTALL_PACKAGE
         for the leftover pre-rename app; without it UninstallerActivity launches
         but silently finishes. Normal-level: granted at install, no prompt. -->
    <uses-permission android:name="android.permission.REQUEST_DELETE_PACKAGES"/>
    <!-- Save a photo to the gallery on pre-Q devices, where writing to
         MediaStore still needs storage permission. On API 29+ the scoped
         MediaStore insert needs no permission, so cap it at 28. -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28"/>
    <application
        android:label="knitcalc"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher">
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/provider_paths"/>
        </provider>
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>
        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
    </application>
    <!-- Required to query activities that can process text, see:
         https://developer.android.com/training/package-visibility and
         https://developer.android.com/reference/android/content/Intent#ACTION_PROCESS_TEXT.

         In particular, this is used by the Flutter engine in io.flutter.plugin.text.ProcessTextPlugin. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
        <!-- The pre-rename package id, so we can detect a leftover install of the
             old app (different applicationId = a separate app) and offer to
             uninstall it. Required for getPackageInfo visibility on Android 11+. -->
        <package android:name="com.example.knitcalc"/>
        <!-- Resolve the system uninstaller so ACTION_DELETE / ACTION_UNINSTALL_PACKAGE
             can launch it; without these, resolveActivity returns null and
             startActivity throws ActivityNotFoundException on Android 11+. -->
        <intent>
            <action android:name="android.intent.action.DELETE"/>
            <data android:scheme="package"/>
        </intent>
        <intent>
            <action android:name="android.intent.action.UNINSTALL_PACKAGE"/>
            <data android:scheme="package"/>
        </intent>
    </queries>
</manifest>
